# ══════════════════════════════════════════════════════════════
# Fingerprint Orchestrator — Environment Variables
# Copy this file to .env and fill in the values
# ══════════════════════════════════════════════════════════════

# ── FastAPI ──────────────────────────────────────────────────
APP_NAME=Fingerprint Orchestrator
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=false

# ── MQTT / Mosquitto ─────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=orchestrator-main
MQTT_KEEPALIVE=60

# ── Worker Management ───────────────────────────────────────
WORKER_HEARTBEAT_TIMEOUT=30

# ── MinIO (public endpoint for remote workers) ──────────────
# Set this to orchestrator/Tailscale IP so worker can download presigned URLs.
MINIO_PUBLIC_ENDPOINT=100.100.108.30:9000
